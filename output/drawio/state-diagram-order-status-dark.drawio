        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e293b;strokeColor=#334155;strokeWidth=1;fontColor=#cbd5e1;fontSize=11;fontFamily=Microsoft YaHei;arcSize=8;" value="图例：红色=待支付/退款　橙色=已支付　蓝色=待发货　紫色=运输中　绿色=已签收/已完成　灰色=已取消" vertex="1">
