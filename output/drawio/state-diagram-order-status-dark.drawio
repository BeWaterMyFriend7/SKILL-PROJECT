        <mxCell id="s-done" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1abc9c;strokeColor=#16a34a;strokeWidth=2;fontColor=#0f172a;fontSize=12;fontStyle=1;shadow=0;" value="已完成" vertex="1">
          <mxGeometry height="50" width="110" x="830" y="300" as="geometry" />
