  <diagram id="case-er-02-light" name="IM系统ER图-浅色">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="620" math="0" shadow="1">
      <root>
        <mxCell id="0" />
