        <mxCell id="e-attach" parent="1" value="附件 (Attachment)&#xa;────────────&#xa;+ attach_id: int (PK)&#xa;+ file_name: varchar(100)&#xa;+ file_url: varchar(200)&#xa;+ msg_id: bigint (FK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3498db;strokeWidth=2;fontColor=#334155;fontSize=11;align=left;spacingLeft=12;spacingTop=5;" vertex="1">
