        <mxCell id="e-user" parent="1" value="用户 (User)&#xa;────────────&#xa;+ user_id: int (PK)&#xa;+ nickname: varchar(50)&#xa;+ avatar: varchar(200)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3498db;strokeWidth=2;fontColor=#334155;fontSize=11;align=left;spacingLeft=12;spacingTop=5;" vertex="1">
