          <mxGeometry height="110" width="200" x="400" y="80" as="geometry" />
        </mxCell>
        <mxCell id="e-msg" parent="1" value="消息 (Message)&#xa;────────────&#xa;+ msg_id: bigint (PK)&#xa;+ content: text&#xa;+ send_time: datetime&#xa;+ sender_id: int (FK)&#xa;+ group_id: int (FK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3498db;strokeWidth=2;fontColor=#334155;fontSize=11;align=left;spacingLeft=12;spacingTop=5;" vertex="1">
          <mxGeometry height="140" width="220" x="50" y="260" as="geometry" />
