<mxfile host="app.diagrams.net">
  <diagram name="火车票订票流程图">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1400" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title" value="高并发火车票订票流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap=1;rounded=0;fontSize=24;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- 开始节点 -->
        <mxCell id="start" value="开始" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3498db;strokeColor=#3498db;strokeWidth=2;fontColor=#ffffff;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="80" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- 用户登录 -->
        <mxCell id="login" value="用户登录&#xa;身份验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#3498db;strokeWidth=2;fontColor=#333333;fontSize=14;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="170" width="120" height="60" as="geometry" />
        </mxCell>
        
        <!-- 登录判断 -->
        <mxCell id="login_check" value="登录成功?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#e67e22;strokeWidth=2;fontColor=#333333;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="520" y="270" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- 登录失败 -->
        <mxCell id="login_fail" value="返回登录页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#e74c3c;strokeWidth=2;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="280" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- 查询车次 -->
        <mxCell id="query_train" value="查询车次信息&#xa;(出发地/目的地/日期)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#3498db;strokeWidth=2;fontColor=#333333;fontSize=14;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="390" width="160" height="60" as="geometry" />
        </mxCell>
        
        <!-- 缓存查询 -->
        <mxCell id="cache_query" value="查询Redis缓存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2ecc71;strokeWidth=2;fontColor=#333333;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="480" width="100" height="50" as="geometry" />
        </mxCell>
        
        <!-- 缓存判断 -->
        <mxCell id="cache_check" value="缓存命中?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#e67e22;strokeWidth=2;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="560" width="80" height="70" as="geometry" />
        </mxCell>
        
        <!-- 缓存未命中 -->
        <mxCell id="db_query" value="查询MySQL&#xa;车次表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2ecc71;strokeWidth=2;fontColor=#333333;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="555" width="90" height="50" as="geometry" />
        </mxCell>
        
        <!-- 回填缓存 -->
        <mxCell id="fill_cache" value="回填Redis缓存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2ecc71;strokeWidth=2;fontColor=#333333;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="490" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- 返回车次列表 -->
        <mxCell id="train_list" value="返回车次列表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#3498db;strokeWidth=2;fontColor=#333333;fontSize=14;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="480" width="120" height="50" as="geometry" />
