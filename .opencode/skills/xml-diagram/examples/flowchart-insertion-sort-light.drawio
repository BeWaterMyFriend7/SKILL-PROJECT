        <mxCell id="legend" value="图例" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontColor=#666666;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="580" width="50" height="20" as="geometry" />
