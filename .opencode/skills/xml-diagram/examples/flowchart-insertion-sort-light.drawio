        <mxCell id="legend_text1" value="操作步骤" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="65" y="598" width="60" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="legend_diamond" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e67e22;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="35" y="625" width="20" height="20" as="geometry" />
