        <mxCell id="legend_line1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3498db;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="605" width="30" height="2" as="geometry" />
