        <mxCell id="legend_text2" value="判断条件" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="65" y="625" width="60" height="20" as="geometry" />
