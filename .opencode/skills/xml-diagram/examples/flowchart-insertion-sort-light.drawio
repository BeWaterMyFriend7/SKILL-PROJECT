        <mxCell id="label_yes2" value="是" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#2ecc71;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="300" width="30" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="label_no2" value="否" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#e74c3c;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="155" y="305" width="30" height="20" as="geometry" />
