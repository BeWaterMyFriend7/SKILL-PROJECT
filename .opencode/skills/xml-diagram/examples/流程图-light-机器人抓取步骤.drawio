<mxfile host="app.diagrams.net" modified="2026-06-14T00:00:00.000Z" agent="xml-diagram" version="24.7.17">
  <diagram id="simple-step-flow-robot-grasp" name="机器人抓取简约步骤流程图">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e0e0e0;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="620" as="geometry" />
        </mxCell>
        <mxCell id="title" value="机器人抓取简约步骤流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#0f172a;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="250" y="28" width="400" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="视觉感知 → 抓取规划 → 执行反馈" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#64748b;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="250" y="64" width="400" height="22" as="geometry" />
        </mxCell>
        <mxCell id="line" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e2e8f0;strokeColor=#e2e8f0;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="96" width="820" height="1" as="geometry" />
        </mxCell>

        <mxCell id="step1" value="1. 图像采集&#xa;━━━━━━&#xa;相机/RGB-D 传感器获取场景数据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3498db;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="125" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="2. 图像预处理&#xa;━━━━━━&#xa;去噪、增强、坐标归一化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3498db;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="265" y="125" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="3. 目标检测&#xa;━━━━━━&#xa;识别目标类别、位置和轮廓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2ecc71;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="475" y="125" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="4. 抓取点计算&#xa;━━━━━━&#xa;计算夹爪姿态和抓取评分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2ecc71;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="685" y="125" width="170" height="92" as="geometry" />
        </mxCell>

        <mxCell id="step5" value="5. 运动规划&#xa;━━━━━━&#xa;生成机械臂路径和避障轨迹" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9b59b6;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="685" y="285" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="6. 抓取执行&#xa;━━━━━━&#xa;机械臂移动并闭合夹爪" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9b59b6;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="475" y="285" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="step7" value="7. 质量检测&#xa;━━━━━━&#xa;根据力反馈和视觉结果判断成功" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9b59b6;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="265" y="285" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="step8" value="8. 放置完成&#xa;━━━━━━&#xa;移动到目标位置并释放物体" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9b59b6;strokeWidth=2;fontColor=#334155;fontSize=12;fontStyle=1;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="285" width="170" height="92" as="geometry" />
        </mxCell>

        <mxCell id="note1" value="神经网络模块&#xa;━━━━━━&#xa;目标检测、姿态估计、抓取评分模型只作为步骤说明，不展开复杂支线。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;strokeWidth=1;fontColor=#334155;fontSize=12;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="430" width="350" height="92" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="闭环反馈&#xa;━━━━━━&#xa;抓取失败时回到图像采集或抓取点计算，由文字说明表达，不额外画回环线。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;strokeWidth=1;fontColor=#334155;fontSize=12;fontFamily=Microsoft YaHei;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="430" width="350" height="92" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3498db;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3498db;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2ecc71;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2ecc71;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9b59b6;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="step5" target="step6">
