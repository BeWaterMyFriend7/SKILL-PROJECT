<mxfile host="app.diagrams.net">
  <diagram name="时序图-用户登录">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" pageWidth="800" pageHeight="480" pageBackground="#f8f9fa">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 标题 -->
        <mxCell id="title" value="用户登录时序图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== 生命线 ===== -->
        <mxCell id="lifeline-ui" value="" style="endArrow=none;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="150" y="80" as="sourcePoint"/>
            <mxPoint x="150" y="420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lifeline-auth" value="" style="endArrow=none;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="80" as="sourcePoint"/>
            <mxPoint x="360" y="420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="lifeline-db" value="" style="endArrow=none;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="570" y="80" as="sourcePoint"/>
            <mxPoint x="570" y="420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 角色标签 -->
        <mxCell id="actor-ui" value="用户界面" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="55" width="100" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="actor-auth" value="认证服务" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="310" y="55" width="100" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="actor-db" value="数据库" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="520" y="55" width="100" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== 激活条 ===== -->
        <mxCell id="active-ui" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#3498db;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="135" y="100" width="30" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="active-auth" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2ecc71;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="345" y="165" width="30" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="active-db" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e67e22;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="555" y="235" width="30" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 消息 ===== -->
        <!-- 消息1: login(username, password) -->
        <mxCell id="msg1" value="login(username, password)" style="endArrow=classic;endFill=1;html=1;strokeColor=#3498db;strokeWidth=2;labelBackgroundColor=#f8f9fa;fontColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="165" y="120" as="sourcePoint"/>
            <mxPoint x="345" y="120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 消息2: validateCredentials() -->
        <mxCell id="msg2" value="validateCredentials()" style="endArrow=classic;endFill=1;html=1;strokeColor=#3498db;strokeWidth=2;labelBackgroundColor=#f8f9fa;fontColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="375" y="185" as="sourcePoint"/>
            <mxPoint x="555" y="185" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 消息3: SELECT * FROM users WHERE username=? -->
        <mxCell id="msg3" value="SELECT * FROM users WHERE username=?" style="endArrow=classic;endFill=1;html=1;strokeColor=#999999;strokeWidth=2;labelBackgroundColor=#f8f9fa;fontColor=#666666;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="555" y="235" as="sourcePoint"/>
            <mxPoint x="555" y="265" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 消息4: verifyPassword() -->
        <mxCell id="msg4" value="verifyPassword()" style="endArrow=classic;endFill=1;html=1;strokeColor=#3498db;strokeWidth=2;labelBackgroundColor=#f8f9fa;fontColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="375" y="305" as="sourcePoint"/>
            <mxPoint x="555" y="305" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 消息5: 返回验证结果 -->
        <mxCell id="msg5" value="返回验证结果" style="endArrow=classic;endFill=1;html=1;strokeColor=#999999;strokeWidth=2;labelBackgroundColor=#f8f9fa;fontColor=#666666;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="555" y="355" as="sourcePoint"/>
            <mxPoint x="375" y="355" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 消息6: 登录成功/失败 -->
        <mxCell id="msg6" value="登录成功/失败" style="endArrow=classic;endFill=1;html=1;strokeColor=#999999;strokeWidth=2;labelBackgroundColor=#f8f9fa;fontColor=#666666;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="345" y="395" as="sourcePoint"/>
            <mxPoint x="165" y="395" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== 结束激活条 ===== -->
        <mxCell id="active-ui-end" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3498db;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="135" y="165" width="30" height="5" as="geometry"/>
        </mxCell>
        <mxCell id="active-auth-end" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2ecc71;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="345" y="255" width="30" height="5" as="geometry"/>
        </mxCell>
        <mxCell id="active-db-end" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e67e22;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="555" y="300" width="30" height="5" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
