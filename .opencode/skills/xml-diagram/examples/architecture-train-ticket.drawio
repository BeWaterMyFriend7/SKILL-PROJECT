        <mxCell id="features-box" value="架构特点&#xa;────────────&#xa;🔴 高并发：分布式锁 + 缓存预热 + 异步处理&#xa;🟢 高可用：服务熔断 + 降级策略 + 集群部署&#xa;🔵 可扩展：微服务架构 + 水平扩展 + 容器化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e0e0e0;strokeWidth=1;fontColor=#333333;fontSize=10;align=left;spacingLeft=15;spacingTop=8;" vertex="1" parent="1">
