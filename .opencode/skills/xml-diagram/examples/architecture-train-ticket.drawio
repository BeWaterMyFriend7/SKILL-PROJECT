<mxfile host="app.diagrams.net">
  <diagram name="架构图-火车票系统">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" pageWidth="1200" pageHeight="900" pageBackground="#f8f9fa">
