        <!-- 用户购物旅程 -->
        <mxCell id="user-journey" value="用户购物旅程&#xa;━━━━━━━━━━&#xa;浏览 | 购买 | 评价&#xa;收藏 | 分享 | 咨询" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3b82f6;strokeColor=#2563eb;fontColor=#ffffff;fontSize=13;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="95" width="160" height="90" as="geometry" />
