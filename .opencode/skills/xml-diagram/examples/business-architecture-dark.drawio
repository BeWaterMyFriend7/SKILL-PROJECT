<mxfile host="app.diagrams.net">
  <diagram name="业务架构图">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="820" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 深色背景 -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1000" height="820" as="geometry" />
        </mxCell>

        <!-- 标题 -->
        <mxCell id="title" value="业务架构图设计案例" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap=1;rounded=0;fontSize=24;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="380" y="15" width="240" height="35" as="geometry" />
        </mxCell>

        <!-- ========== 第一层：业务场景层 ========== -->
        <mxCell id="layer1-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e2a4a;strokeColor=#7b86f7;strokeWidth=2;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="20" y="50" width="960" height="165" as="geometry" />
        </mxCell>
        <mxCell id="layer1-title" value="业务场景层 (Business Scenario Layer)" style="text;html=1;strokeColor=#7b86f7;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap=1;rounded=0;fontSize=16;fontStyle=1;fontColor=#7b86f7;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="260" height="25" as="geometry" />
